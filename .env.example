# ── Discord ────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# ── Supabase ───────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Discord Channel IDs ────────────────────────────────────────
CHANNEL_GENERAL_ID=
CHANNEL_RESOURCES_ID=
CHANNEL_DAILY_CHECK_IN_ID=
CHANNEL_TRADE_JOURNAL_ID=
CHANNEL_WEEKLY_GOALS_ID=
CHANNEL_DISCIPLINE_LOG_ID=
CHANNEL_PROGRESS_TRACKER_ID=
CHANNEL_REPORTS_ID=
CHANNEL_REMINDERS_ID=   # optional — set to enable morning + evening reminders

# ── Runtime ────────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata
DAILY_REPORT_CRON=0 22 * * *
WEEKLY_REPORT_CRON=0 20 * * 0
MONTHLY_REPORT_CRON=0 20 1 * *
CHECKIN_REMINDER_CRON=0 9 * * 1-5
DISCIPLINE_REMINDER_CRON=0 18 * * 1-5
LOG_LEVEL=info
